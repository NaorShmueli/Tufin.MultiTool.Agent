{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Agent": {
    "MaxSteps": 8,
    "MaxToolCallsPerStep": 4,
    "Temperature": 0
  },

  "OpenMeteo": {
    "GeocodingBaseUrl": "https://geocoding-api.open-meteo.com",
    "ForecastBaseUrl": "https://api.open-meteo.com",
    "TimeoutSeconds": 10
  }
}

